{
  "name": "@elevora-tech/mailcap",
  "version": "0.1.0",
  "description": "Zero-branching email SDK: captures in dev/staging via Mailcap, delivers for real via Resend, SendGrid, or Mailgun in production.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "keywords": [
    "email",
    "testing",
    "resend",
    "sendgrid",
    "mailgun",
    "sdk"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Elevora-Tech/mailcap-sdk"
  },
  "homepage": "https://github.com/Elevora-Tech/mailcap-sdk#readme",
  "bugs": "https://github.com/Elevora-Tech/mailcap-sdk/issues",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
